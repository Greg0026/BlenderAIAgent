# ─────────────────────────────────────────────────────────────────────
# API KEYS (at least one for operation)
# ─────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxx
OPENCODE_ZEN_API_KEY=ocz-xxxxxxxxxxxxx

# Optional (for corpus_builder.py)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx
STACKEXCHANGE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION
# ─────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_MODEL_ID=deepseek-v4-flash-free
LLM_VISION_MODEL=kimi-k2.6
LLM_FALLBACK_MODELS=qwen3.6-plus-free,minimax-m3-free,nemotron-3-ultra-free,big-pickle,mimo-v2.5-free,north-mini-code-free
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.7
LLM_MAX_TOKENS=16384
F2_MAX_TOKENS=40000

# ─────────────────────────────────────────────────────────────────────
# BLENDER
# ─────────────────────────────────────────────────────────────────────
BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 3.0\blender.exe
BLENDER_TIMEOUT=120

# ─────────────────────────────────────────────────────────────────────
# PIPELINE
# ─────────────────────────────────────────────────────────────────────
ERROR_LOOPS=8
FIX_LOOPS=6
PHASE_TIMEOUT=300
MIN_CODE_LENGTH=400
STL_OUTPUT_DIR=~/Desktop/blender_prints
VISION_RENDER_DIR=
VISION_REVIEW_ENABLED=true
MAX_MESH_FIX_ATTEMPTS=3
MAX_FIDELITY_REVIEW_PASSES=3
STATIC_MAX_LEN=40000

# API retry
FIRST_CHUNK_TIMEOUT=30
API_BASE_DELAY=3.0
API_MAX_RETRIES=3
API_INTER_PAUSE=8.0
RETRY_BACKOFF_S=1.0

# ─────────────────────────────────────────────────────────────────────
# BATCH RUNNER (afk.py)
# ─────────────────────────────────────────────────────────────────────
BATCH_LLM_MODEL=openai/gpt-oss-120b:free
BATCH_MAX_JOBS=
BATCH_PAUSE=10
